@model SubastaArte.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar usuario";
}

<header class="mb-3">
    <h1 class="h3 mb-0">Editar usuario</h1>
    <p class="text-muted mb-0">Mantenimiento: edición de perfil de usuario</p>
</header>

<form asp-action="Edit" method="post" asp-route-id="@Model.IdUsuario" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="IdUsuario" type="hidden" />

    <div class="col-md-6">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" autocomplete="off" />
        <span id="nombre-custom-error" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Apellido1" class="form-label"></label>
        <input asp-for="Apellido1" class="form-control" autocomplete="off" />
        <span id="apellido1-custom-error" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Apellido2" class="form-label"></label>
        <input asp-for="Apellido2" class="form-control" autocomplete="off" />
        <span id="apellido2-custom-error" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" autocomplete="off" />
        <span id="email-custom-error" class="text-danger"></span>
    </div>


    <div class="col-md-6">
        <label class="form-label">Rol</label>
        <input class="form-control bg-light" value="@Model.IdRolNavigation.Descripcion" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">Estado Usuario</label>
        <input class="form-control bg-light" value="@Model.IdEstadoUsuarioNavigation.Nombre" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">Fecha de Registro</label>
        <input class="form-control bg-light" value="@Model.FechaRegistro.ToString("d/M/yyyy HH:mm:ss")" readonly />
    </div>

    @* Mostrar solo la cantidad relevante según el rol *@
    @if (Model.IdRol == 2)
    {
        <div class="col-md-6">
            <label asp-for="CantidadSubastas" class="form-label"></label>
            <input asp-for="CantidadSubastas" class="form-control bg-light" readonly />
        </div>
    }
    else if (Model.IdRol == 3)
    {
        <div class="col-md-6">
            <label asp-for="CantidadPujas" class="form-label"></label>
            <input asp-for="CantidadPujas" class="form-control bg-light" readonly />
        </div>
    }

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            let hasErrors = false;

            // Validar nombre
            const nombre = document.querySelector('input[name="Nombre"]');
            const nombreError = document.getElementById('nombre-custom-error');
            
            if (!nombre.value.trim()) {
                nombreError.textContent = 'El nombre es requerido';
                nombreError.style.display = 'block';
                hasErrors = true;
            } else {
                nombreError.style.display = 'none';
            }

            // Validar apellido1
            const apellido1 = document.querySelector('input[name="Apellido1"]');
            const apellido1Error = document.getElementById('apellido1-custom-error');
            
            if (!apellido1.value.trim()) {
                apellido1Error.textContent = 'El primer apellido es requerido';
                apellido1Error.style.display = 'block';
                hasErrors = true;
            } else {
                apellido1Error.style.display = 'none';
            }

            // Validar apellido2
            const apellido2 = document.querySelector('input[name="Apellido2"]');
            const apellido2Error = document.getElementById('apellido2-custom-error');
            
            if (!apellido2.value.trim()) {
                apellido2Error.textContent = 'El segundo apellido es requerido';
                apellido2Error.style.display = 'block';
                hasErrors = true;
            } else {
                apellido2Error.style.display = 'none';
            }

            // Validar email
            const email = document.querySelector('input[name="Email"]');
            const emailError = document.getElementById('email-custom-error');

            if (!email.value.trim()) {
                emailError.textContent = 'El correo electrónico es requerido';
                emailError.style.display = 'block';
                hasErrors = true;
            } else {
                emailError.style.display = 'none';
            }

            if (hasErrors) {
                e.preventDefault();
            }
        });
    </script>
}

















   

