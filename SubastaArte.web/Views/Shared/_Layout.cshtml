<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Subasta Arte</title>
    <script type="importmap"></script>
    <!--Preconección (mejorar carga CDN)-->
    <link rel="preconnect" href="https://cdnjs.cloudfare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!--Boostrap 5.3.8-->
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap-Pulse.min.css" />
    <!--Boostrap Icons-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <!--SweetAlert 2-->
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />
    <!-- Multi-select (depende de Bootstrap + jQuery) -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/1.1.2/css/bootstrap-multiselect.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!--Estilos propios-->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SubastaArte.Web.styles.css" asp-append-version="true" />

</head>
<body class="d-flex flex-column min-vh-100 bg-body">
    <!-- Accesibilidad: salto a contenido -->
    <a class="visually-hidden-focusable position-absolute top-0 start-0 p-2 bg-body border rounded"
       href="#mainContent">
        Saltar al contenido
    </a>

    <header class="sticky-top">
        @await Html.PartialAsync("_Menu")
    </header>

    <main id="mainContent" class="flex-grow-1">
        <div class="container py-3">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-auto border-top">
        <div class="container py-3 small text-muted d-flex flex-column flex-md-row gap-2 justify-content-between align-items-md-center">
            <div>
                &copy; @DateTime.Now.Year - Subasta Arte
            </div>
            <div>
                <a class="link-secondary text-decoration-none" asp-area="" asp-controller="Home" asp-action="Privacy">
                    Privacidad
                </a>
            </div>
        </div>
    </footer>

    <!-- jQuery (es necesario para jQuery UI / multiselect / unobtrusive) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Multi-select -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/1.1.2/js/bootstrap-multiselect.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <!--SweetAlert 2-->
    <script src="~/lib/sweetalert2/dist/sweetalert2.all.min.js"></script>
    <!-- SWEETALERT NOTIFICATION -->
    @if (TempData["Notificacion"] != null || ViewBag.Notificacion != null)
    {
        var notificacion = TempData["Notificacion"] ?? ViewBag.Notificacion;
        <script type="text/javascript">
            const payload = @Html.Raw(notificacion);
            if (payload) {
                Swal.fire(payload);
            }
        </script>
    }

    <!-- Campana global: notificaciones temporales en sesión -->
    <!-- Campana global: notificaciones temporales en sesión -->
    <script>
        (function () {
            const storageKey = 'subasta_notificaciones_temp';

            function loadItems() {
                try {
                    return JSON.parse(sessionStorage.getItem(storageKey) ?? '[]');
                } catch {
                    return [];
                }
            }

            function saveItems(items) {
                sessionStorage.setItem(storageKey, JSON.stringify(items));
            }

            function countUnread(items) {
                return items.filter(x => !x.leida).length;
            }

            function renderBell() {
                const list = document.getElementById('menuBellList');
                const badge = document.getElementById('menuBellBadge');
                if (!list || !badge) return;

                const items = loadItems();

                if (!items.length) {
                    list.innerHTML = '<div class="list-group-item text-muted small">No hay notificaciones.</div>';
                    badge.classList.add('d-none');
                    badge.textContent = '0';
                    return;
                }

                const unread = countUnread(items);
                if (unread > 0) {
                    badge.classList.remove('d-none');
                    badge.textContent = unread.toString();
                } else {
                    badge.classList.add('d-none');
                    badge.textContent = '0';
                }

                list.innerHTML = items
                    .slice()
                    .reverse()
                    .map(n => `
                        <div class="list-group-item ${n.leida ? 'opacity-75' : ''}" data-id="${n.id}">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="pe-2">
                                    <div class="fw-semibold small">${n.titulo}</div>
                                    <div class="small text-muted">${n.mensaje}</div>
                                    <div class="small text-secondary">${n.fecha}</div>
                                </div>
                                <button type="button"
                                        class="btn btn-sm ${n.leida ? 'btn-outline-secondary' : 'btn-outline-success'} menuBellMarkRead"
                                        ${n.leida ? 'disabled' : ''}>
                                    ${n.leida ? 'Leída' : 'Marcar leída'}
                                </button>
                            </div>
                        </div>
                    `)
                    .join('');
            }

            function addNotification(titulo, mensaje) {
                const items = loadItems();
                items.push({
                    id: Date.now() + Math.floor(Math.random() * 1000),
                    titulo: titulo || 'Notificación',
                    mensaje: mensaje || '',
                    fecha: new Date().toLocaleString('es-CR'),
                    leida: false
                });
                saveItems(items);
                renderBell();
            }

            function markRead(id) {
                const items = loadItems();
                const updated = items.map(x => String(x.id) === String(id) ? { ...x, leida: true } : x);
                saveItems(updated);
                renderBell();
            }

            function markAllRead() {
                const items = loadItems();
                const updated = items.map(x => ({ ...x, leida: true }));
                saveItems(updated);
                renderBell();
            }

            function clearNotifications() {
                saveItems([]);
                renderBell();
            }

            window.SubastaBell = {
                add: addNotification,
                markAllRead: markAllRead,
                clear: clearNotifications,
                render: renderBell
            };

            document.addEventListener('DOMContentLoaded', function () {
                renderBell();

                const clearBtn = document.getElementById('menuBellClear');
                if (clearBtn) {
                    clearBtn.addEventListener('click', function (e) {
                        e.preventDefault();
                        markAllRead();
                    });
                }

                const list = document.getElementById('menuBellList');
                if (list) {
                    list.addEventListener('click', function (e) {
                        const btn = e.target.closest('.menuBellMarkRead');
                        if (!btn || btn.disabled) return;

                        const item = btn.closest('[data-id]');
                        if (!item) return;

                        const id = item.getAttribute('data-id');
                        markRead(id);
                    });
                }
            });

            document.addEventListener('subasta:notificacion', function (event) {
                const detail = event.detail || {};
                if (!detail.mensaje) return;
                addNotification(detail.titulo || 'Notificación', detail.mensaje);
            });
        })();
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>