@*@model IEnumerable<SubastaArte.Application.DTOs.SubastaDTO>  *@
@model X.PagedList.IPagedList<SubastaArte.Application.DTOs.SubastaDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Administración de Subastas Activas";
    var total = Model?.Count() ?? 0;
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Gestión de Subastas Activas</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Subastas Activas</h1>
        <p class="text-muted mb-0">Gestión administrativa de subastas activas. Total: <strong>@total</strong>.</p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nueva Subasta
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-body d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado</span>

        <span class="small text-muted">
            Mostrando
            <strong>@Model?.FirstItemOnPage</strong>–
            <strong>@Model?.LastItemOnPage</strong>
            de <strong>@Model?.TotalItemCount</strong>
        </span>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center">
                <div class="display-6 mb-2"><i class="bi bi-inbox"></i></div>
                <h2 class="h5">No hay Subastas Activas</h2>
                <p class="text-muted mb-3">Crea la primera Subasta para iniciar.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Crear Subasta
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light position-sticky top-0" style="z-index:1;">
                        <tr>
                            <th class="ps-3" style="width:80px;">  @Html.DisplayNameFor(model => model.First().Nombre)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().FechaInicio)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().FechaCierre)</th>
                            <th class="text-center" style="width:120px;">Imagen</th>
                            <th class="text-center" style="width:170px;">  Cantidad de Pujas</th>
                            <th class="text-center" style="width:220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="badge text-bg-light border">@item.Nombre</span>
                                </td>
                                <td class="text-center"><span class="font-monospace">@item.FechaInicio</span></td>
                                <td class="text-center"><span class="font-monospace">@item.FechaCierre</span></td>
                                <td class="text-center align-middle">
                                    @{
                                        var imagen = item.IdObjetoNavigation.Foto.FirstOrDefault();
                                    }

                                    @if (imagen != null)
                                    {
                                        <img style="width:125px; height:125px; object-fit:cover;"
                                             src="data:image/jpeg;base64,@Convert.ToBase64String(imagen.Foto)"
                                             alt="Imagen"
                                             loading="lazy" />
                                    }
                                </td>
                                <td class="text-center"><span class="font-monospace">@item.PujasSubasta</span></td>
                                <td class="text-center">
                                    <div class="btn-group" role="group" aria-label="Acciones">
                                        <a asp-action="Details" asp-route-id="@item.IdSubasta" class="btn btn-outline-secondary px-3 py-2">
                                            <i class="bi bi-eye"></i><span class="d-none d-lg-inline ms-1">Detalle</span>
                                        </a>

                                        @* Botón Editar (con validación de pujas) *@
                                        <button type="button" class="btn btn-outline-primary px-3 py-2"
                                                data-subasta-id="@item.IdSubasta"
                                                data-subasta-nombre="@item.Nombre"
                                                data-pujas-cantidad="@item.PujasSubasta"
                                                onclick="handleEditarActivaClick(this)">
                                            <i class="bi bi-pencil-square"></i><span class="d-none d-lg-inline ms-1">Editar</span>
                                        </button>

                                        @* Botón Cancelar (con validación de pujas) - SIN MODIFICAR *@
                                        <button type="button" class="btn btn-outline-danger px-3 py-2"
                                                data-subasta-id="@item.IdSubasta"
                                                data-subasta-nombre="@item.Nombre"
                                                data-pujas-cantidad="@item.PujasSubasta"
                                                onclick="handleCancelarActivaClick(this)">
                                            <i class="bi bi-x-circle"></i><span class="d-none d-lg-inline ms-1">Cancelar</span>
                                        </button>
                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Paginación *@
    @if (Model != null && Model.PageCount > 1)
    {
        <div class="card-footer bg-body d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
            <div class="small text-muted">
                Página <strong>@Model.PageNumber</strong> de <strong>@Model.PageCount</strong>
            </div>

            <nav aria-label="Paginación de Subastas Activas">
                @Html.PagedListPager(
                         Model,
                         page => Url.Action("IndexSA", new { page }),
                         new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },

                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,

                MaximumPageNumbersToDisplay = 5
            }
                         )
            </nav>
        </div>
    }

    <!-- MODAL DE CONFIRMACIÓN PARA CANCELAR SUBASTA ACTIVA -->
    <div class="modal fade" id="cancelarActivaModal" tabindex="-1" aria-labelledby="cancelarActivaModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0 bg-danger text-white">
                    <h5 class="modal-title fw-bold" id="cancelarActivaModalLabel">
                        <i class="bi bi-x-circle me-2"></i>Confirmar Cancelación de Subasta Activa
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-4 pb-3">
                    <div class="text-center mb-4">
                        <div class="display-1 mb-3 text-danger">
                            <i class="bi bi-x-circle"></i>
                        </div>
                        <h6 class="fw-semibold mb-3 text-dark">¿Está seguro que desea cancelar esta subasta activa?</h6>
                        <div class="p-3 rounded-3 mb-3 bg-light border-start border-4 border-danger">
                            <p class="mb-1 text-dark">
                                <strong>ID:</strong> <span id="modalCancelarActivaSubastaId" class="fw-semibold"></span>
                            </p>
                            <p class="mb-1 text-dark">
                                <strong>Nombre:</strong> <span id="modalCancelarActivaSubastaNombre" class="fw-semibold"></span>
                            </p>
                            <p class="mb-0 text-dark">
                                <strong>Pujas:</strong> <span id="modalCancelarActivaPujas" class="fw-semibold"></span>
                            </p>
                        </div>
                        <div class="alert alert-warning border-0 small mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Esta acción no se puede deshacer. La subasta quedará cancelada permanentemente.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg me-1"></i>No cancelar
                    </button>
                    <form id="cancelarActivaForm" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="idEstadoSubasta" value="4" />
                        <button type="submit" class="btn btn-danger px-4 fw-semibold">
                            <i class="bi bi-x-circle me-1"></i>Cancelar Subasta
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function handleCancelarActivaClick(button) {
                const subastaId = button.getAttribute('data-subasta-id');
                const subastaNombre = button.getAttribute('data-subasta-nombre');
                const pujasCantidad = parseInt(button.getAttribute('data-pujas-cantidad'));

                // Validar si tiene pujas
                if (pujasCantidad > 0) {
                    // Mostrar SweetAlert de error si tiene pujas
                    Swal.fire({
                        title: 'No se puede cancelar',
                        text: `No se puede cancelar la subasta "${subastaNombre}" porque ya tiene ${pujasCantidad} puja(s) registrada(s).`,
                        icon: 'error',
                        confirmButtonText: 'Entendido',
                        confirmButtonColor: '#dc3545'
                    });
                    return;
                }

                // Si no tiene pujas, mostrar modal de confirmación
                document.getElementById('modalCancelarActivaSubastaId').textContent = subastaId;
                document.getElementById('modalCancelarActivaSubastaNombre').textContent = subastaNombre;
                document.getElementById('modalCancelarActivaPujas').textContent = pujasCantidad;

                // Configurar formulario
                const cancelarForm = document.getElementById('cancelarActivaForm');
                cancelarForm.action = '@Url.Action("ChangeEstado", "Subasta", new { returnTo = "IndexSA" })';


                // Agregar campo hidden para el ID
                let hiddenId = cancelarForm.querySelector('input[name="id"]');
                if (!hiddenId) {
                    hiddenId = document.createElement('input');
                    hiddenId.type = 'hidden';
                    hiddenId.name = 'id';
                    cancelarForm.appendChild(hiddenId);
                }
                hiddenId.value = subastaId;

                // Mostrar el modal
                const cancelarModal = new bootstrap.Modal(document.getElementById('cancelarActivaModal'));
                cancelarModal.show();
            }

                 // NUEVA FUNCIÓN para editar
                function handleEditarActivaClick(button) {
                    const subastaId = button.getAttribute('data-subasta-id');
                    const subastaNombre = button.getAttribute('data-subasta-nombre');
                    const pujasCantidad = parseInt(button.getAttribute('data-pujas-cantidad'));

                    // Validar si tiene pujas
                    if (pujasCantidad > 0) {
                        // Mostrar SweetAlert de error si tiene pujas
                        Swal.fire({
                            title: 'No se puede editar',
                            text: `No se puede editar la subasta "${subastaNombre}" porque ya tiene ${pujasCantidad} puja(s) registrada(s).`,
                            icon: 'error',
                            confirmButtonText: 'Entendido',
                            confirmButtonColor: '#dc3545'
                        });
                        return;
                    }

                    // Si no tiene pujas, redirigir a Edit con parámetro returnTo
                       const baseUrl = '@Url.Action("Edit", "Subasta")';
                       window.location.href = `${baseUrl}/${subastaId}?returnTo=IndexSA`;
        
                }      
        </script>
        
      }


</div>
