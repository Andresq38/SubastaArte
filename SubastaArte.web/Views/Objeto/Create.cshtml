@model SubastaArte.Application.DTOs.ObjetoDTO

@{
    ViewData["Title"] = "Crear Objeto";
    var categorias = ViewBag.ListCategorias as MultiSelectList;
    var vendedor = ViewBag.Vendedor as SubastaArte.Application.DTOs.UsuarioDTO;
}

<header class="mb-3">
    <h1 class="h3 mb-0">Crear objeto subastable</h1>
    <p class="text-muted mb-0">Mantenimiento: registro de un nuevo objeto para subasta</p>
</header>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-12">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" autocomplete="off" />
    </div>

    <div class="col-12">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
    </div>

    <div class="col-md-6">
        <label asp-for="Condicion" class="form-label"></label>
        <select asp-for="Condicion" class="form-select">
            <option value="">Seleccione una condición</option>
            <option value="Nuevo">Nuevo</option>
            <option value="Como nuevo">Como nuevo</option>
            <option value="Excelente estado">Excelente estado</option>
            <option value="Muy buen estado">Muy buen estado</option>
            <option value="Buen estado">Buen estado</option>
            <option value="Estado aceptable">Estado aceptable</option>
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">Estado Objeto</label>
        <input class="form-control" value="Activo" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">Usuario vendedor</label>
        <input class="form-control" value="@(vendedor != null ? $"{vendedor.Nombre} {vendedor.Apellido1} {vendedor.Apellido2}" : "Vendedor no encontrado")" readonly />
    </div>

    <div class="col-12">
        <label class="form-label">Categorías</label>
        <select id="selectedCategorias"
                name="selectedCategorias"
                class="form-select"
                asp-items="categorias"
                multiple>
        </select>
        <span id="selectedCategorias-error" class="text-danger"></span>
        <div class="form-text">Puede seleccionar múltiples categorías.</div>
    </div>


    <div class="col-12">
        <label class="form-label" for="imagenes">Imágenes</label>
        <input type="file"
               id="imagenes"
               name="imagenes"
               class="form-control"
               accept="image/*"
               multiple
               required />
        <span asp-validation-for="Foto" class="text-danger" id="imagen-error"></span>
        <figure class="mt-3">
            <figcaption class="text-muted small mt-2">Previsualización de las imágenes seleccionadas.</figcaption>
        </figure>

    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Guardar
        </button>
        <a asp-action="IndexAdmin" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const input = document.getElementById('imagenes');
        const previewContainer = document.createElement('div');
        previewContainer.className = 'd-flex flex-wrap gap-2 mt-2';
        const figure = document.querySelector('figure');
        figure.appendChild(previewContainer);

        input?.addEventListener('change', (e) => {
            // Limpiar previews anteriores
            previewContainer.innerHTML = '';

            const files = input.files;
            if (!files || files.length === 0) {
                previewContainer.innerHTML = '';
                return;
            }

            Array.from(files).forEach(file => {
                const img = document.createElement('img');
                img.className = 'img-thumbnail';
                img.style.maxHeight = '120px';
                img.style.maxWidth = '120px';
                img.style.objectFit = 'cover';
                img.alt = 'Previsualización';
                img.src = URL.createObjectURL(file);
                previewContainer.appendChild(img);
            });
        });


        // Bootstrap Multiselect
        $(document).ready(function () {
            if ($.fn.multiselect) {
                $('#selectedCategorias').multiselect({
                    buttonClass: 'form-select',
                    templates: {
                        button: '<button type="button" class="multiselect dropdown-toggle" data-bs-toggle="dropdown"><span class="multiselect-selected-text"></span></button>',
                    },
                    includeSelectAllOption: true,
                    selectAllText: 'Seleccionar todas',
                    allSelectedText: 'Todas las opciones',
                    nonSelectedText: 'Seleccione una opción',
                    nSelectedText: ' - seleccionadas',
                });
            }
        });

            document.querySelector('form').addEventListener('submit', function (e) {
            let hasErrors = false;

            // Limpiar errores anteriores
            $('#nombre-custom-error, #descripcion-custom-error, #condicion-custom-error, #selectedCategorias-error, #imagen-error').text('').hide();

            // 1. VALIDAR NOMBRE
            const nombre = $('input[name="Nombre"]').val();
            if (!nombre || nombre.trim() === '') {
                if (!$('#nombre-custom-error').length) {
                    $('input[name="Nombre"]').after('<span id="nombre-custom-error" class="text-danger"></span>');
                }
                $('#nombre-custom-error').text('El nombre del objeto es requerido').show();
                hasErrors = true;
            }

            // 2. VALIDAR DESCRIPCIÓN (mínimo 20 caracteres)
            const descripcion = $('textarea[name="Descripcion"]').val();
            if (!descripcion || descripcion.trim() === '') {
                if (!$('#descripcion-custom-error').length) {
                    $('textarea[name="Descripcion"]').after('<span id="descripcion-custom-error" class="text-danger"></span>');
                }
                $('#descripcion-custom-error').text('La descripción es requerida').show();
                hasErrors = true;
            } else if (descripcion.trim().length < 20) {
                if (!$('#descripcion-custom-error').length) {
                    $('textarea[name="Descripcion"]').after('<span id="descripcion-custom-error" class="text-danger"></span>');
                }
                $('#descripcion-custom-error').text('La descripción debe tener al menos 20 caracteres').show();
                hasErrors = true;
            }

            // 3. VALIDAR CONDICIÓN
            const condicion = $('select[name="Condicion"]').val();
            if (!condicion || condicion === '') {
                if (!$('#condicion-custom-error').length) {
                    $('select[name="Condicion"]').after('<span id="condicion-custom-error" class="text-danger"></span>');
                }
                $('#condicion-custom-error').text('Debe seleccionar una condición del objeto').show();
                hasErrors = true;
            }

            // 4. VALIDAR IMÁGENES
            const imageInput = document.getElementById('imagenes');
            const imageError = document.getElementById('imagen-error');

            if (imageInput && imageInput.files.length === 0) {
                if (imageError) {
                    imageError.textContent = "Debe agregar al menos 1 imagen del objeto a subastar";
                    imageError.style.display = 'block';
                }
                hasErrors = true;
            } else if (imageError) {
                imageError.textContent = "";
                imageError.style.display = 'none';
            }

            // 5. VALIDAR CATEGORÍAS
            const categoriaSelect = document.getElementById('selectedCategorias');
            const categoriaError = document.getElementById('selectedCategorias-error');

            if (!categoriaSelect.value || categoriaSelect.selectedOptions.length === 0) {
                if (categoriaError) {
                    categoriaError.textContent = "Debe seleccionar al menos una categoria";
                    categoriaError.style.display = 'block';
                }
                hasErrors = true;
            } else if (categoriaError) {
                categoriaError.textContent = "";
                categoriaError.style.display = 'none';
            }

            if (hasErrors) {
                e.preventDefault();
            }
        });


    </script>
}
