@*@model IEnumerable<SubastaArte.Application.DTOs.ObjetoDTO>  *@
@model X.PagedList.IPagedList<SubastaArte.Application.DTOs.SubastaDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Administración de Subastas por Objeto";
    var total = Model?.Count() ?? 0;
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Gestión subastas por Objeto</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Subastas por Objeto</h1>
        <p class="text-muted mb-0">Gestión administrativa de subastas por Objeto. Total: <strong>@total</strong>.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-controller="Objeto" asp-action="Details" asp-route-id="@Model.First().IdObjeto" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver al Detalle objeto
        </a>
    </div>

</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-body d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado se subastas por Objeto</span>

        <span class="small text-muted">
            Mostrando
            <strong>@Model?.FirstItemOnPage</strong>–
            <strong>@Model?.LastItemOnPage</strong>
            de <strong>@Model?.TotalItemCount</strong>
        </span>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center">
                <div class="display-6 mb-2"><i class="bi bi-inbox"></i></div>
                <h2 class="h5">No hay subastas registradas</h2>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light position-sticky top-0" style="z-index:1;">
                        <tr>
                            <th class="ps-3" style="width:80px;">  @Html.DisplayNameFor(model => model.First().IdSubasta)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().FechaInicio)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().FechaCierre)</th>
                            <th class="text-center" style="width:120px;">@Html.DisplayNameFor(model => model.First().IdEstadoSubastaNavigation)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var subasta in Model)
                            {
                                <tr>
                                    <td class="ps-3">
                                        @subasta.IdSubasta
                                    </td>

                                    <td class="text-center">
                                        @subasta.FechaInicio.ToShortDateString()
                                    </td>

                                    <td class ="text-center">
                                        @subasta.FechaCierre.ToShortDateString()
                                    </td>

                                    <td class ="text-center">
                                        @(subasta.IdEstadoSubastaNavigation?.Nombre ?? "Sin estado")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    Sin subastas
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Paginación *@
    @if (Model != null && Model.PageCount > 1)
    {
        <div class="card-footer bg-body d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
            <div class="small text-muted">
                Página <strong>@Model.PageNumber</strong> de <strong>@Model.PageCount</strong>
            </div>

            <nav aria-label="Paginación de Objetos">
                @Html.PagedListPager(
                         Model,
                         page => Url.Action("IndexAdmin", new { page }),
                         new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },

                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,

                MaximumPageNumbersToDisplay = 5
            }
                         )
            </nav>
        </div>
    }
</div>