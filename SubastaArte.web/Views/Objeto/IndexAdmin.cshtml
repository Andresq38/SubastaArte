@*@model IEnumerable<SubastaArte.Application.DTOs.ObjetoDTO>  *@
@model X.PagedList.IPagedList<SubastaArte.Application.DTOs.ObjetoDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Administración de Objetos para Subastar";
    var total = Model?.Count() ?? 0;
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Gestión de Objetos a Subastar</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Objetos para Subastar</h1>
        <p class="text-muted mb-0">Gestión administrativa del catálogo. Total: <strong>@total</strong>.</p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nuevo Objeto
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-body d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado</span>

        <span class="small text-muted">
            Mostrando
            <strong>@Model?.FirstItemOnPage</strong>–
            <strong>@Model?.LastItemOnPage</strong>
            de <strong>@Model?.TotalItemCount</strong>
        </span>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center">
                <div class="display-6 mb-2"><i class="bi bi-inbox"></i></div>
                <h2 class="h5">No hay Objetos registrados</h2>
                <p class="text-muted mb-3">Crea el primer Objeto para iniciar el catálogo.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Crear Objeto
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light position-sticky top-0" style="z-index:1;">
                        <tr>
                            <th class="ps-3" style="width:80px;">  @Html.DisplayNameFor(model => model.First().Nombre)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().IdVendedorNavigation)</th>
                            <th class="text-center" style="width:170px;">  @Html.DisplayNameFor(model => model.First().Condicion)</th>
                            <th class="text-center" style="width:120px;">@Html.DisplayNameFor(model => model.First().Foto)</th>
                            <th class="text-center" style="width:220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="badge text-bg-light border">@item.Nombre</span>
                                </td>
                                <td class="text-center"><span class="font-monospace">@item.IdVendedorNavigation.Nombre  @item.IdVendedorNavigation.Apellido1  @item.IdVendedorNavigation.Apellido2</span></td>
                                <td class="text-center"><span class="font-monospace">@item.Condicion</span></td>
                                <td class="text-center align-middle">
                                    @{
                                        var imagen = item.Foto.FirstOrDefault();
                                    }

                                    @if (imagen != null)
                                    {
                                        <img style="width:125px; height:125px; object-fit:cover;"
                                             src="data:image/jpeg;base64,@Convert.ToBase64String(imagen.Foto)"
                                             alt="Imagen"
                                             loading="lazy" />
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group" aria-label="Acciones">
                                        <a asp-action="Details" asp-route-id="@item.IdObjeto" class="btn btn-outline-secondary px-3 py-2">
                                            <i class="bi bi-eye"></i><span class="d-none d-lg-inline ms-1">Detalle</span>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IdObjeto" class="btn btn-outline-primary px-3 py-2">
                                            <i class="bi bi-pencil-square"></i><span class="d-none d-lg-inline ms-1">Editar</span>
                                        </a>

                                        @{
                                            // Verificar si el objeto pertenece a subastas activas o finalizadas
                                            bool puedeEliminar = item.Subasta?.Any(s => s.IdEstadoSubasta == 1 || s.IdEstadoSubasta == 2) != true;
                                        }

                                        <button type="button" class="btn btn-outline-danger px-3 py-2"
                                                data-objeto-id="@item.IdObjeto"
                                                data-objeto-nombre="@item.Nombre"
                                                data-puede-eliminar="@puedeEliminar.ToString().ToLower()"
                                                onclick="handleDeleteClick(this)">
                                            <i class="bi bi-trash"></i><span class="d-none d-lg-inline ms-1">Eliminar</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Paginación *@
    @if (Model != null && Model.PageCount > 1)
    {
        <div class="card-footer bg-body d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
            <div class="small text-muted">
                Página <strong>@Model.PageNumber</strong> de <strong>@Model.PageCount</strong>
            </div>

            <nav aria-label="Paginación de Objetos">
                @Html.PagedListPager(
                         Model,
                         page => Url.Action("IndexAdmin", new { page }),
                         new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },

                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,

                MaximumPageNumbersToDisplay = 5
            }
                         )
            </nav>
        </div>
    }
</div>

<!-- MODAL DE CONFIRMACIÓN DE ELIMINACIÓN -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0 bg-primary text-white">
                <h5 class="modal-title fw-bold" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4 pb-3">
                <div class="text-center mb-4">
                    <div class="display-1 mb-3 text-primary">
                        <i class="bi bi-trash"></i>
                    </div>
                    <h6 class="fw-semibold mb-3 text-dark">¿Está seguro que desea eliminar este objeto?</h6>
                    <div class="p-3 rounded-3 mb-3 bg-light border-start border-4 border-primary">
                        <p class="mb-1 text-dark">
                            <strong>ID:</strong> <span id="modalObjetoId" class="fw-semibold"></span>
                        </p>
                        <p class="mb-0 text-dark">
                            <strong>Nombre:</strong> <span id="modalObjetoNombre" class="fw-semibold"></span>
                        </p>
                    </div>
                    <div class="alert alert-warning border-0 small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Esta acción no se puede deshacer y eliminará también todas las imágenes asociadas.
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancelar
                </button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4 fw-semibold">
                        <i class="bi bi-trash me-1"></i>Eliminar Objeto
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function handleDeleteClick(button) {
            const objetoId = button.getAttribute('data-objeto-id');
            const objetoNombre = button.getAttribute('data-objeto-nombre');
            const puedeEliminar = button.getAttribute('data-puede-eliminar') === 'true';

            if (!puedeEliminar) {
                // Mostrar SweetAlert de error
                Swal.fire({
                    title: 'No se puede eliminar',
                    text: `No se puede eliminar el objeto "${objetoNombre}" porque pertenece a una subasta activa o finalizada.`,
                    icon: 'error',
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#dc3545'
                });
                return;
            }

            // Si se puede eliminar, mostrar el modal
            document.getElementById('modalObjetoId').textContent = objetoId;
            document.getElementById('modalObjetoNombre').textContent = objetoNombre;

            const deleteForm = document.getElementById('deleteForm');
            deleteForm.action = '@Url.Action("Delete", "Objeto")/' + objetoId;

            // Mostrar el modal
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }
    </script>
}
