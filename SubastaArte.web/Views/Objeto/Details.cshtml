@model SubastaArte.Application.DTOs.ObjetoDTO

@{
    ViewData["Title"] = "Detalle del Objeto";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Objeto" asp-action="Index" class="text-decoration-none">Catálogo</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Detalle</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Detalle del objeto</h1>
        <p class="text-muted mb-0">Información completa del objeto seleccionado.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-controller="Objeto" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver al catálogo
        </a>

        @{
            // Verificar si el objeto pertenece a subastas activas o finalizadas
            bool puedeEliminar = Model.Subasta?.Any(s => s.IdEstadoSubasta == 1 || s.IdEstadoSubasta == 2) != true;
        }

        <button type="button" class="btn btn-outline-danger"
                data-objeto-id="@Model.IdObjeto"
                data-objeto-nombre="@Model.Nombre"
                data-puede-eliminar="@puedeEliminar.ToString().ToLower()"
                onclick="handleDeleteClick(this)">
            <i class="bi bi-trash me-1"></i> Eliminar
        </button>
    </div>
</div>

<article class="card shadow-sm border-0 overflow-hidden">
    <div class="row g-0">

        <!-- Imagen / portada -->
        <div class="col-12 col-lg-5 bg-body-tertiary p-3">
            @if (Model.Foto != null && Model.Foto.Any())
            {
                <div id="carouselObjeto" class="carousel slide carousel-dark" data-bs-ride="carousel">
                    <div class="carousel-inner text-center">

                        @{
                            var primera = true;
                        }

                        @foreach (var img in Model.Foto)
                        {
                            @* Una forma de ver imagenes *@
                            @*  <div class="carousel-item @(primera ? "active" : "")">
                                <img class="w-100 rounded"
                                     style="max-height:500px; object-fit:cover;"
                                     src="data:image/jpeg;base64,@Convert.ToBase64String(img.Foto)"
                                     alt="Imagen de @Model.Nombre"
                                     loading="lazy" />
                            </div> *@

                            @* Otra forma de ver imagenes *@
                            <div class="carousel-item @(primera ? "active" : "") text-center">

                                <img class="img-fluid rounded"
                                     style="max-height:500px; object-fit:contain; background-color:#f8f9fa;"
                                     src="data:image/jpeg;base64,@Convert.ToBase64String(img.Foto)"
                                     alt="Imagen de @Model.Nombre"
                                     loading="lazy" />

                            </div>

                            primera = false;
                        }
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselObjeto" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>

                    <button class="carousel-control-next" type="button" data-bs-target="#carouselObjeto" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            }
        </div>

        <!-- Contenido -->
        <div class="col-12 col-lg-7">
            <div class="card-body p-4">

                <header class="mb-3">
                    <h2 class="h4 fw-semibold mb-1">@Model.Nombre</h2>

                    <div class="d-flex flex-wrap gap-2 align-items-center">

                        @* <span class="badge text-bg-light">
                            <i class="bi bi-award me-1"></i>
                           @Model.Condicion
                        </span> *@

                        @{
                            var esActivo = Model.IdEstadoObjeto == 1;
                            var colorEstado = esActivo ? "text-bg-success" : "text-bg-danger";
                            var iconoEstado = esActivo ? "bi-check-lg" : "bi-x-lg";
                        }

                        <span class="badge @colorEstado">
                            <i class="@iconoEstado me-1"></i>
                            @Model.IdEstadoObjetoNavigation.Nombre
                        </span>

                    </div>
                </header>

                <hr class="my-3" />

                <!-- Datos clave -->
                <dl class="row mb-0">
                    <dt class="col-12 col-md-4 text-muted">Desripcion Objeto</dt>
                    <dd class="col-12 col-md-8">
                        @Model.Descripcion
                    </dd>

                    <dt class="col-12 col-md-4 text-muted">Vendedor</dt>
                    <dd class="col-12 col-md-8">
                        @Model.IdVendedorNavigation.Nombre @Model.IdVendedorNavigation.Apellido1 @Model.IdVendedorNavigation.Apellido2
                    </dd>

                    <dt class="col-12 col-md-4 text-muted">Condicion Objeto</dt>
                    <dd class="col-12 col-md-8">
                        @Model.Condicion
                    </dd>

                    <dt class="col-12 col-md-4 text-muted">Fecha Registro</dt>
                    <dd class="col-12 col-md-8">
                        @(Model.FechaRegistro)
                    </dd>

                    <dt class="col-12 col-md-4 text-muted">Categorías</dt>
                    <dd class="col-12 col-md-8">
                        @if (Model.IdCategoria != null && Model.IdCategoria.Any())
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var c in Model.IdCategoria)
                                {
                                    <span class="badge text-bg-light border">
                                        <i class="bi bi-tag me-1"></i>@c.Nombre
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">Sin categorías asociadas.</span>
                        }
                    </dd>
                </dl>

                <hr class="my-4" />

                <!-- Acciones -->
                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                    <a asp-controller="Objeto" asp-action="IndexAdmin" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Regresar al listado
                    </a>

                    <a asp-controller="Objeto" asp-action="SubastasObjetos" asp-route-idObjeto="@Model.IdObjeto" class="btn btn-outline-primary">
                        <i class="bi bi-clock-history me-1"></i> Historial de Subastas
                    </a>
                </div>

            </div>
        </div>
    </div>
</article>

<!-- MODAL DE CONFIRMACIÓN DE ELIMINACIÓN -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0 bg-primary text-white">
                <h5 class="modal-title fw-bold" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4 pb-3">
                <div class="text-center mb-4">
                    <div class="display-1 mb-3 text-primary">
                        <i class="bi bi-trash"></i>
                    </div>
                    <h6 class="fw-semibold mb-3 text-dark">¿Está seguro que desea eliminar este objeto?</h6>
                    <div class="p-3 rounded-3 mb-3 bg-light border-start border-4 border-primary">
                        <p class="mb-1 text-dark">
                            <strong>ID:</strong> @Model.IdObjeto
                        </p>
                        <p class="mb-0 text-dark">
                            <strong>Nombre:</strong> <span class="fw-semibold">@Model.Nombre</span>
                        </p>
                    </div>
                    <div class="alert alert-warning border-0 small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Esta acción no se puede deshacer y eliminará también todas las imágenes asociadas.
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancelar
                </button>
                <form asp-action="Delete" asp-route-id="@Model.IdObjeto" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4 fw-semibold">
                        <i class="bi bi-trash me-1"></i>Eliminar Objeto
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function handleDeleteClick(button) {
        const objetoId = button.getAttribute('data-objeto-id');
        const objetoNombre = button.getAttribute('data-objeto-nombre');
        const puedeEliminar = button.getAttribute('data-puede-eliminar') === 'true';

        if (!puedeEliminar) {
            // Mostrar SweetAlert de error
            Swal.fire({
                title: 'No se puede eliminar',
                text: `No se puede eliminar el objeto "${objetoNombre}" porque pertenece a una subasta activa o finalizada.`,
                icon: 'error',
                confirmButtonText: 'Entendido',
                confirmButtonColor: '#dc3545'
            });
            return;
        }

        // Si se puede eliminar, mostrar el modal
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
        deleteModal.show();
    }
</script>

