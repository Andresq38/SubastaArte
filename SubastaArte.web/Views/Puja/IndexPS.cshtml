@* @model IEnumerable<SubastaArte.Application.DTOs.PujaDTO> *@
@model X.PagedList.IPagedList<SubastaArte.Application.DTOs.PujaDTO>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Administración de Pujas por Subasta";
    var total = Model?.Count() ?? 0;
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Gestión de pujas por subasta</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Pujas por Subasta</h1>
        <p class="text-muted mb-0">Gestión administrativa de pujas por subasta. Total: <strong>@total</strong>.</p>
    </div>
    @* Posible solucion para retornar sin tener que definir estados y demas *@
    <div class="d-flex gap-2">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver al Detalle objeto
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-body d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado</span>

        <span class="small text-muted">
            Mostrando
            <strong>@Model?.FirstItemOnPage</strong>–
            <strong>@Model?.LastItemOnPage</strong>
            de <strong>@Model?.TotalItemCount</strong>
        </span>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center">
                <div class="display-6 mb-2"><i class="bi bi-inbox"></i></div>
                <h2 class="h5">No hay pujas registradas</h2>
                <p class="text-muted mb-3">Crea la primera Puja para iniciar.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Crear Puja
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light position-sticky top-0" style="z-index:1;">
                        <tr>
                            <th class="ps-3" style="width:80px;">ID subasta</th>
                            <th class="ps-3" style="width:80px;">Nombre subasta</th>
                            <th class="text-center" style="width:170px;">Usuario que realizo la puja</th>
                            <th class="text-center" style="width:170px;">Monto Ofertado</th>
                            <th class="text-center" style="width:120px;">Fecha y Hora de la Puja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="badge text-bg-light border">@item.IdSubasta</span>
                                </td>
                                <td class="text-center"><span class="font-monospace">@item.IdSubastaNavigation.Nombre</span></td>
                                <td class="text-center"><span class="font-monospace">@item.IdUsuarioNavigation.Nombre @item.IdUsuarioNavigation.Apellido1 @item.IdUsuarioNavigation.Apellido2</span></td>
                                <td class="text-center"><span class="font-monospace">@item.Monto</span></td>
                                <td class="text-center"><span class="font-monospace">@item.FechaHora</span></td>
                                
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* Paginación *@
    @if (Model != null && Model.PageCount > 1)
    {
        <div class="card-footer bg-body d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
            <div class="small text-muted">
                Página <strong>@Model.PageNumber</strong> de <strong>@Model.PageCount</strong>
            </div>

            <nav aria-label="Paginación de Subastas Activas">
                @Html.PagedListPager(
                         Model,
                         page => Url.Action("IndexPS", new { page }),
                         new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" },

                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,

                MaximumPageNumbersToDisplay = 5
            }
                         )
            </nav>
        </div>
    }
</div>